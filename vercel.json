{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "taxiayud.com" }],
      "destination": "https://www.taxiayud.es/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.taxiayud.com" }],
      "destination": "https://www.taxiayud.es/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "taxiayud.es" }],
      "destination": "https://www.taxiayud.es/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=()" }
      ]
    }
  ]
}
