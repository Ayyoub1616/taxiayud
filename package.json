{
  "name": "taxiayud",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build && cp -R public/. dist/ && node scripts/generate-static-pages.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -b --pretty false",
    "lint": "tsc -b --pretty false",
    "seo:check": "node scripts/seo-check.mjs",
    "test": "node scripts/seo-check.mjs && node scripts/smoke-check.mjs",
    "check": "pnpm build && pnpm test"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.8.3",
    "vite": "^8.1.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7"
  }
}
